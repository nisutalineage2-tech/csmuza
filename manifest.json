{
  "manifest_version": 3,
  "name": "CSFloat Profit Finder",
  "version": "1.0.0",
  "description": "Muestra el profit de skins CS2 comparando CSFloat con Steam Market",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://csfloat.com/*",
    "https://steamcommunity.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://csfloat.com/*"],
      "js": ["js/content.js"],
      "css": ["css/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  }
}
